{
  "servers": {
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=gsjyabekiucdkzhulvip"
    },
    "kanban": {
      "type": "stdio",
      "command": "node",
      "args": ["${workspaceFolder}/mcp-server/dist/index.js"],
      "env": {
        "AGENTPLANNER_API_KEY": "${input:apiKey}",
        "AGENTPLANNER_URL": "${input:appUrl}"
      }
    }
  },
  "inputs": [
    {
      "id": "apiKey",
      "type": "promptString",
      "description": "Your AgentPlanner API key (generate one from Profile → API Keys)"
    },
    {
      "id": "appUrl",
      "type": "promptString",
      "description": "AgentPlanner URL (e.g. https://d1abc2def3.cloudfront.net or http://localhost:3000)"
    }
  ]
}
